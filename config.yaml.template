# === Data Collection ===
data:
  monitored_pairs:
    - BTC/USD
    - ETH/USD
    - SOL/USD
    - AVAX/USD
    - LINK/USD
  timeframes:
    - 1m
    - 1h
    - 4h
    - 1d
  orderbook_depth: 10
  collection_interval_seconds: 60
  backfill_days: 180

# === Risk Limits ===
risk:
  circuit_breaker_drawdown_pct: 0.30
  position_loss_trigger_pct: 0.25
  global_max_gross_exposure: 0.80
  global_max_pair_exposure: 0.50
  global_max_concurrent_positions: 10
  default_max_positions_per_agent: 5
  minimum_order_usd: 5.0

# === Wake Controller ===
wake_controller:
  min_cadence_hours: 1
  max_cadence_hours: 24
  cooldown_minutes: 30
  max_triggers_per_window: 2

# === Robustness Testing ===
robustness:
  n_runs: 1000
  random_seed: 42
  min_trades: 8

# === System Improvement Reviews ===
system_improvements:
  review_cadence: weekly
  review_day: sunday
  max_requests_per_agent_per_cycle: 3
  auto_decline_after_weeks: 8

# === Logging ===
logging:
  level: INFO
  format: json
  retention_days: 30

# === Dry Run ===
# If true, log everything but place no real orders
dry_run: true
